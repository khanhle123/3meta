# Cross-platform line-ending normalization
# All text files are stored as LF in the repo and checked out as LF on every OS.
* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.py        text eol=lf

# Docs and config
*.md        text eol=lf
*.markdown  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.svg       text eol=lf

# Shell scripts must stay LF or they break on Linux/macOS
*.sh        text eol=lf

# Windows-only scripts: keep CRLF so cmd.exe runs them correctly
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Lock files are diffable text
package-lock.json   text eol=lf linguist-generated=true
yarn.lock           text eol=lf linguist-generated=true
pnpm-lock.yaml      text eol=lf linguist-generated=true

# Binary assets — never diffed, never normalized
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.webm  binary
