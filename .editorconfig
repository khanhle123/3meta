# EditorConfig keeps indentation, charset and line endings consistent
# across editors and operating systems. See https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Markdown: trailing spaces denote line breaks
[*.md]
trim_trailing_whitespace = false

# Windows shell scripts must keep CRLF
[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
